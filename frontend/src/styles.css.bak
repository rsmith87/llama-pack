:root {
  color: #17201b;
  background: #f4efe5;
  color-scheme: light;
  font-family: ui-sans-serif, system-ui, sans-serif;
  --ink: #17201b;
  --muted: #66716b;
  --page: #f4efe5;
  --page-glow: rgba(215, 119, 53, 0.2);
  --panel: rgba(255, 252, 245, 0.9);
  --sidebar: rgba(23, 32, 27, 0.94);
  --sidebar-ink: #fff9ee;
  --sidebar-hover: rgba(255, 255, 255, 0.12);
  --line: rgba(34, 48, 40, 0.14);
  --accent: #d77735;
  --accent-dark: #8b3f1d;
  --accent-soft: rgba(215, 119, 53, 0.22);
  --card: rgba(255, 255, 255, 0.55);
  --card-strong: rgba(255, 255, 255, 0.72);
  --button: rgba(255, 255, 255, 0.6);
  --input: rgba(255, 255, 255, 0.74);
  --code-bg: rgba(31, 37, 31, 0.06);
  --shadow: rgba(23, 32, 27, 0.08);
  --shadow-strong: rgba(23, 32, 27, 0.16);
  --success: #25633f;
  --success-bg: rgba(50, 128, 82, 0.16);
  --warning: #8b3f1d;
  --warning-bg: rgba(215, 119, 53, 0.18);
  --danger: #9b2f24;
  --danger-bg: rgba(155, 47, 36, 0.14);
  --danger-line: rgba(155, 47, 36, 0.35);
  --chat-user: rgba(231, 244, 226, 0.72);
  --log-bg: #151914;
  --log-ink: #e8f0df;
}

:root[data-theme="dark"] {
  color: #eff7fb;
  background: #071014;
  color-scheme: dark;
  --ink: #eff7fb;
  --muted: #94a9b5;
  --page: #071014;
  --page-glow: rgba(19, 194, 214, 0.16);
  --panel: rgba(17, 29, 38, 0.88);
  --sidebar: rgba(5, 13, 17, 0.98);
  --sidebar-ink: #e7f5fb;
  --sidebar-hover: rgba(20, 188, 211, 0.12);
  --line: rgba(138, 174, 190, 0.2);
  --accent: #18c7d6;
  --accent-dark: #75d8e7;
  --accent-soft: rgba(24, 199, 214, 0.16);
  --card: rgba(24, 39, 50, 0.74);
  --card-strong: rgba(29, 48, 61, 0.88);
  --button: rgba(27, 45, 58, 0.9);
  --input: rgba(4, 14, 20, 0.78);
  --code-bg: rgba(2, 8, 12, 0.72);
  --shadow: rgba(0, 0, 0, 0.28);
  --shadow-strong: rgba(0, 0, 0, 0.42);
  --success: #41e493;
  --success-bg: rgba(65, 228, 147, 0.15);
  --warning: #ffd15c;
  --warning-bg: rgba(255, 209, 92, 0.15);
  --danger: #ff7f86;
  --danger-bg: rgba(255, 118, 99, 0.15);
  --danger-line: rgba(255, 118, 99, 0.34);
  --chat-user: rgba(19, 151, 167, 0.2);
  --log-bg: #02080c;
  --log-ink: #d7edf5;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: var(--page);
}

a {
  color: inherit;
}

.app-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 236px 1fr;
  background:
    linear-gradient(rgba(138, 174, 190, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(138, 174, 190, 0.035) 1px, transparent 1px),
    radial-gradient(circle at top left, var(--page-glow), transparent 30%),
    var(--page);
  background-size: 32px 32px, 32px 32px, auto, auto;
}

.app-sidebar {
  padding: 22px 14px;
  border-right: 1px solid var(--line);
  background: var(--sidebar);
  color: var(--sidebar-ink);
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.mobile-menu-button,
.mobile-nav-scrim {
  display: none;
}

.page-heading {
  margin-bottom:20px;
  display: flex;
  flex-wrap: nowrap;
  align-items: flex-end;
  justify-content: space-between;
}

.page-heading h2{
  margin-bottom: 10px;
}

.brand-lockup {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 4px 6px 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.11);
}

.brand-mark {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  background: linear-gradient(145deg, #184d5b, #0b2730);
  border: 1px solid rgba(117, 216, 231, 0.45);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
}

.brand-logo {
  width: 28px;
  height: 28px;
  display: block;
}

.logo-chip,
.logo-neck {
  fill: #1b241d;
}

.logo-face {
  fill: #fff6e6;
}

.logo-eye {
  fill: #1b241d;
}

.logo-ear,
.logo-line {
  fill: none;
  stroke: #fff6e6;
  stroke-width: 3.2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.brand-lockup h1,
.panel h2,
.page-heading h2 {
  margin: 0;
}

.brand-lockup h1 {
  font-size: 15px;
  line-height: 1.15;
}

.brand-lockup p,
.panel p {
  margin: 4px 0 0;
  color: var(--muted);
}

.brand-lockup p {
  color: rgba(255, 249, 238, 0.62);
  font-size: 12px;
}

.app-nav {
  display: grid;
  gap: 6px;
}

.nav-button {
  border: 0;
  border-radius: 8px;
  padding: 9px 10px;
  background: transparent;
  color: inherit;
  text-align: left;
  font: inherit;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 11px;
  min-height: 40px;
  opacity: 0.82;
  transition: background 140ms ease, color 140ms ease, opacity 140ms ease, transform 140ms ease;
}

.nav-button.active,
.nav-button:hover {
  background: var(--sidebar-hover);
  opacity: 1;
}

.nav-button.active {
  color: #f5fdff;
  border: 1px solid rgba(24, 199, 214, 0.5);
  box-shadow: inset 3px 0 0 var(--accent), 0 0 18px rgba(24, 199, 214, 0.08);
}

.nav-button:hover {
  transform: translateX(1px);
}

.nav-icon {
  width: 19px;
  height: 19px;
  flex: 0 0 19px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.nav-button.active .nav-icon {
  color: var(--accent-dark);
}

.modal-nav-button {
  margin-top: 8px;
  border-top: 1px solid rgba(255, 255, 255, 0.11);
  padding-top: 16px;
}

.sidebar-footer {
  margin-top: auto;
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}

.pill {
  border-radius: 10px;
  padding: 5px 9px;
  background: var(--accent-soft);
  color: #ffd8bd;
  font-size: 12px;
}

.muted {
  color: var(--muted);
}

.app-main {
  min-width: 0;
}

.app-header {
  min-height: 64px;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  border-bottom: 1px solid var(--line);
}

.global-status {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  color: var(--muted);
  font-size: 13px;
}

.status-dot {
  width: 9px;
  height: 9px;
  border-radius: 10px;
  background: var(--muted);
}

.status-dot.online {
  background: var(--success);
}

.status-dot.offline {
  background: var(--danger);
}

.header-actions {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 12px;
  flex-wrap: wrap;
}

.command-center {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--muted);
  min-width: 180px;
}

.command-icon {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  background: var(--ink);
  color: #fff9ee;
}

.command-icon .brand-logo {
  width: 25px;
  height: 25px;
}

.command-copy {
  color: var(--ink);
  font-weight: 750;
}

.layout {
  padding: 18px 20px;
}

.panel {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 14px;
  background: var(--panel);
  box-shadow: 0 20px 60px var(--shadow);
  margin-bottom: 10px;
}

.eyebrow {
  display: block;
  color: var(--accent-dark);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.ghost-link {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 8px 12px;
  text-decoration: none;
  background: var(--button);
}

.dashboard-page {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
  gap: 18px;
}

.dashboard-health,
.quick-actions-panel {
  grid-column: 1 / -1;
}

.panel-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(120px, 1fr));
  gap: 12px;
}

.metric-grid > div,
.model-card,
.node-card,
.quick-action {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  background: var(--card);
}

.label,
.model-card span,
.node-card span,
.node-card small,
.quick-action small {
  display: block;
  color: var(--muted);
  font-size: 13px;
}

.model-card strong,
.model-card span {
  margin-top: 5px;
  margin-bottom: 5px;
}

.model-card button {
  margin-left: 10px;
}

.model-card-detail-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 8px;
  margin: 4px 0 0;
}

.model-card-detail-grid div {
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: 14px;
  padding: 9px 10px;
}

.model-card-detail-grid dt {
  color: var(--muted);
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.model-card-detail-grid dd {
  margin: 3px 0 0;
  color: var(--ink);
  font-weight: 700;
  word-break: break-word;
}

.model-cards,
.nodes-list,
.quick-actions {
  display: grid;
  gap: 12px;
}

.quick-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

button.ghost-button,
.quick-action {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 8px 12px;
  background: var(--button);
  color: var(--ink);
  cursor: pointer;
  font-size: 12px;
}

button.ghost-button:hover,
.actions button:hover,
.auth-form button:hover,
.theme-toggle:hover {
  border-color: rgba(24, 199, 214, 0.55);
  box-shadow: 0 0 0 1px rgba(24, 199, 214, 0.12);
}

.quick-action {
  border-radius: 10px;
  text-align: left;
}

.empty,
.error-text {
  color: var(--muted);
}

.error-text {
  color: var(--danger);
}

.settings-pane {
  margin-bottom: 10px;
}

.settings-tabs {
  margin-bottom: 10px;
}

.settings-tabs button {
  margin-right: 5px;
  padding: 5px 10px;
}

@media (max-width: 1080px) {
  .dashboard-page,
  .quick-actions,
  .metric-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 880px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .app-sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 30;
    width: min(82vw, 320px);
    border-right: 1px solid var(--line);
    transform: translateX(-100%);
    transition: transform 160ms ease;
  }

  .app-shell.mobile-nav-open .app-sidebar {
    transform: translateX(0);
  }

  .mobile-menu-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 10px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: var(--button);
    color: var(--ink);
    cursor: pointer;
  }

  .mobile-menu-button .nav-icon {
    width: 20px;
    height: 20px;
  }

  .mobile-nav-scrim {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 20;
    border: 0;
    background: rgba(0, 0, 0, 0.38);
  }

  .app-header {
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .command-center {
    flex: 1;
  }

  .header-actions,
  .global-status {
    width: 100%;
    justify-content: flex-start;
  }
}

.status-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 3px 7px;
  font-size: 11px;
  font-weight: 700;
}

.status-badge-success {
  background: var(--success-bg);
  color: var(--success);
}

.status-badge-warning {
  background: var(--warning-bg);
  color: var(--warning);
}

.status-badge-danger {
  background: var(--danger-bg);
  color: var(--danger);
}

.status-badge-muted {
  background: rgba(102, 113, 107, 0.14);
  color: var(--muted);
}

.table-wrap {
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

.data-table th,
.data-table td {
  border-bottom: 1px solid var(--line);
  padding: 9px 10px;
  text-align: left;
  font-size: 12px;
  vertical-align: middle;
}

.data-table th {
  color: var(--muted);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  display: grid;
  place-items: center;
  background: rgba(0, 0, 0, 0.48);
  z-index: 10;
}

.modal-panel,
.drawer {
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel);
  padding: 22px;
  box-shadow: 0 20px 60px var(--shadow-strong);
}

.modal-panel {
  width: min(720px, calc(100vw - 32px));
}

.drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(420px, 100vw);
  height: 100vh;
  transform: translateX(100%);
  transition: transform 160ms ease;
  z-index: 9;
}

.drawer.open {
  transform: translateX(0);
}

.form-field {
  display: grid;
  gap: 6px;
}

.streaming-text {
  white-space: pre-wrap;
  margin: 0;
  color: var(--ink);
}

.auth-form {
  display: flex;
  align-items: end;
  gap: 8px;
  flex-wrap: wrap;
}

.auth-form .form-field {
  min-width: 120px;
}

.auth-form input {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 8px 10px;
  background: var(--input);
  color: var(--ink);
}

.auth-form button,
.theme-toggle {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 8px 12px;
  background: var(--button);
  color: var(--ink);
  cursor: pointer;
}

.theme-toggle {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  white-space: nowrap;
}

.filter-bar,
.nodes-filter-bar,
.controller-filters {
  display: flex;
  align-items: end;
  gap: 12px;
  flex-wrap: wrap;
  margin: 0 0 0px;
}

.controller-filters {
  margin-bottom: 10px;
}

.filter-bar input,
.filter-bar select,
.node-edit-form input,
.library-controls input,
.library-controls select,
.controller-filters input,
.controller-filters select,
.log-modal-controls input,
.log-modal-controls select {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 9px 10px;
  background: var(--input);
  color: var(--ink);
}

.controller-filters button,
.log-modal-controls button,
button.primary {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 9px 13px;
  background: var(--button);
  color: var(--ink);
  cursor: pointer;
}

button.primary {
  background: var(--accent);
  color: #1d140e;
  font-weight: 700;
}

.nodes-page-list {
  display: grid;
  gap: 14px;
}

.node {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 16px;
  background: var(--card);
}

.node-header,
.node-header-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.node-url {
  color: var(--muted);
  font-size: 13px;
  margin-top: 3px;
}

.node-meta-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(120px, 1fr));
  gap: 10px;
  margin: 14px 0;
}

.node-meta-grid > div {
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 10px;
  background: var(--card);
}

.model-actions {
  display: flex;
  gap: 8px;
  margin-top: 10px;
  flex-wrap: wrap;
}

.model-actions button {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 6px 10px;
  background: var(--button);
  color: var(--ink);
  cursor: pointer;
}

.node-edit-form {
  display: grid;
  gap: 14px;
}

.checkbox-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

@media (max-width: 1080px) {
  .node-header,
  .node-header-actions {
    align-items: flex-start;
    flex-direction: column;
  }

  .node-meta-grid {
    grid-template-columns: 1fr;
  }
}

.library-sections,
.library-cards {
  display: grid;
  gap: 14px;
}

.library-cards .model-actions button {
  font-size: 11px;
  min-height: 26px;
  padding: 4px 8px;
}

.library-cards .model-actions button:nth-child(1) {
  border-color: rgba(55, 213, 229, 0.7);
  background: linear-gradient(135deg, #14b8c7, #0f7f91);
  color: #061014;
  font-weight: 800;
}

.library-cards .model-actions button:nth-child(2) {
  color: var(--danger);
}

.library-card {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  background: linear-gradient(180deg, var(--card-strong), var(--card));
  display: grid;
  gap: 10px;
}

.library-card-button {
  display: grid;
  gap: 10px;
  text-align: left;
  border: 0;
  padding: 0;
  background: transparent;
  color: inherit;
  cursor: pointer;
}

.library-card-button span,
.library-card-button small {
  color: var(--muted);
}

.library-card-button strong {
  font-size: 14px;
  line-height: 1.25;
}

.library-card-meta {
  display: grid;
  grid-template-columns: 104px minmax(0, 1fr);
  gap: 7px 10px;
  margin: 0;
  font-size: 11px;
}

.library-card-meta div {
  display: contents;
}

.library-card-meta dt {
  color: var(--muted);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.library-card-meta dd {
  margin: 0;
  color: var(--ink);
  overflow-wrap: anywhere;
}

.inline-status {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-weight: 800;
}

.inline-status::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 10px currentColor;
}

.inline-status-success {
  color: var(--success);
}

.inline-status-warning {
  color: var(--warning);
}

.library-card-badges,
.modal-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.library-detail,
.library-controls {
  display: grid;
  gap: 14px;
}

.library-controls {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.detail-list {
  display: grid;
  gap: 8px;
  margin: 0;
}

.detail-list div {
  border-bottom: 1px solid var(--line);
  padding-bottom: 8px;
}

.detail-list dt {
  color: var(--muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.detail-list dd {
  margin: 2px 0 0;
  word-break: break-word;
  font-size: 12px;
}

.danger {
  color: var(--danger);
}

.download-form-status {
  align-self: center;
}

.download-panel {
  display: grid;
  gap: 14px;
}

.download-form {
  display: grid;
  grid-template-columns: minmax(220px, 1fr) minmax(180px, 0.8fr) minmax(140px, 0.45fr) minmax(120px, 0.4fr);
  gap: 8px;
  align-items: end;
  margin: 0;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(2, 10, 15, 0.28);
}

.download-form .form-field {
  min-width: 0;
}

.download-form-status {
  grid-column: 1 / -1;
  font-size: 12px;
}

.recommended-downloads {
  display: grid;
  gap: 12px;
  margin-bottom: 0;
}

.recommended-downloads-header {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 16px;
}

.recommended-downloads-header h3 {
  margin: 0;
  font-size: 16px;
}

.recommended-download-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 12px;
}

.recommended-download-card {
  display: grid;
  gap: 8px;
}

.recommended-download-card p {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.4;
}

.recommended-download-card small {
  color: var(--muted);
  word-break: break-word;
}

.recommended-download-meta {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.recommended-download-meta span {
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 4px 8px;
  background: var(--button);
  color: var(--ink);
  font-size: 12px;
}

.recommended-download-meta > span {
  background-color: var(--success);
  color: black;
}

.recommended-download-meta span:nth-child(2) {
  background-color: var(--warning);
  color: black;
}

.recommended-download-card button {
  justify-self: start;
  margin-left: 0;
}

.download-quant-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 12px;
  margin-top: 0px;
}

.download-quant-cards article {
  margin-top: 10px;
}

.actions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.actions button {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 6px 9px;
  background: var(--button);
  color: var(--ink);
  cursor: pointer;
}

.split-page-layout {
  display: grid;
  grid-template-columns: minmax(260px, 340px) minmax(0, 1fr);
  gap: 16px;
  align-items: start;
}

.side-panel {
  position: sticky;
  top: 18px;
}

.stacked-controls {
  display: grid;
  gap: 12px;
}

.advanced-chat-panel,
.chat-session-panel {
  display: grid;
  gap: 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  background: var(--card);
}

.chat-session-panel input,
.chat-session-panel select {
  border: 1px solid var(--line);
  background: var(--input);
  color: var(--ink);
  border-radius: 8px;
  width: 100%;
  padding: 8px 10px;
}

.stacked-controls input,
.stacked-controls select,
.stacked-controls textarea,
.compact-select {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 8px 10px;
  background: var(--input);
  color: var(--ink);
  width: 100%;
}

.detail-json {
  max-height: 320px;
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 12px;
  background: var(--code-bg);
  color: var(--ink);
  white-space: pre-wrap;
}

.controller-grid-react {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.95fr);
  gap: 16px;
  align-items: start;
}

.job-detail-react,
.job-detail-summary {
  display: grid;
  gap: 10px;
}

.job-detail-react h4 {
  margin: 8px 0 0;
}

.inline-json {
  max-width: 340px;
  max-height: 140px;
  overflow: auto;
  margin: 0;
  white-space: pre-wrap;
}

.tall-json {
  max-height: 520px;
}

.compact-json {
  max-height: 180px;
}

.log-modal-controls {
  display: grid;
  grid-template-columns: repeat(5, minmax(120px, 1fr));
  gap: 12px;
  align-items: end;
  margin-bottom: 12px;
}

.modal-log-output {
  min-height: 360px;
  max-height: 62vh;
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 14px;
  background: var(--log-bg);
  color: var(--log-ink);
  white-space: pre-wrap;
}

@media (max-width: 980px) {
  .split-page-layout,
  .controller-grid-react {
    grid-template-columns: 1fr;
  }

  .download-form {
    grid-template-columns: 1fr;
  }

  .log-modal-controls {
    grid-template-columns: 1fr;
  }

  .side-panel {
    position: static;
  }
}

.chat-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(280px, 322px);
  gap: 16px;
  align-items: start;
}

.chat-main-column {
  display: grid;
  gap: 16px;
}

.chat-workbench-panel {
  min-height: calc(100vh - 142px);
  display: flex;
  flex-direction: column;
}

.chat-session-panel-top {
  grid-template-columns: minmax(180px, 1fr) minmax(220px, 1.2fr);
  align-items: end;
}

.chat-session-panel-top .modal-actions {
  grid-column: 1 / -1;
}

.chat-transcript {
  display: grid;
  gap: 12px;
  align-content: start;
  flex: 1;
  min-height: 380px;
  margin-bottom: 16px;
}

.chat-bubble {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  background: var(--card);
}

.chat-bubble-user {
  margin-left: min(12vw, 140px);
  background: var(--chat-user);
}

.chat-bubble-assistant,
.chat-bubble-error {
  margin-right: min(12vw, 140px);
}

.chat-bubble-error {
  border-color: var(--danger-line);
  background: var(--danger-bg);
}

.chat-role {
  display: inline-block;
  color: var(--muted);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.chat-bubble p {
  margin: 0;
  white-space: pre-wrap;
}

.chat-bubble small {
  display: block;
  color: var(--muted);
  margin-top: 8px;
}

.chat-reasoning {
  margin-top: 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--code-bg);
  padding: 8px 10px;
}

.chat-reasoning summary {
  cursor: pointer;
  color: var(--muted);
  font-size: 12px;
  user-select: none;
}

.chat-reasoning pre {
  margin: 8px 0 0;
  white-space: pre-wrap;
  color: var(--ink);
  font-size: 12px;
}

.chat-composer {
  display: grid;
  gap: 10px;
  padding-top: 12px;
  border-top: 1px solid var(--line);
}

.chat-composer textarea {
  width: 100%;
  resize: vertical;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 12px;
  background: var(--input);
  color: var(--ink);
}

.chat-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 0 0 8px;
}

.chat-chip {
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 2px 7px;
  color: var(--muted);
  font-size: 11px;
  background: var(--button);
}

@media (max-width: 980px) {
  .chat-layout {
    grid-template-columns: 1fr;
  }

  .chat-workbench-panel {
    min-height: auto;
  }

  .chat-bubble-user,
  .chat-bubble-assistant,
  .chat-bubble-error {
    margin-left: 0;
    margin-right: 0;
  }
}

.chat-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 0 0 8px;
}

.chat-chip {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 3px 7px;
  background: var(--button);
  color: var(--muted);
  font-size: 12px;
}
