# Copy this file to .neuraxis.env on each machine and replace placeholders.
# .neuraxis.env is ignored by git and may contain local secrets.

# Common runtime bind. Use 127.0.0.1 when Caddy/TLS fronts the app.
# Use 0.0.0.0 only for direct LAN HTTP without Caddy.
export NEURAXIS_HOST=127.0.0.1
export NEURAXIS_PORT=9137

# Controller machine only.
# scripts/onboard_controller.sh writes generated values for fresh controller
# setup. Leave these commented unless you are intentionally reusing real values.
export NEURAXIS_CONFIG=./config.yaml
# export NEURAXIS_CONTROLLER_REGISTRATION_KEY=replace-with-controller-registration-key
# export NEURAXIS_CONTROLLER_ADMIN_API_KEY=replace-with-admin-api-key
export NEURAXIS_MAC_MINI_AGENT_URL=https://mac-mini.local
export NEURAXIS_LINUX_2080TI_AGENT_URL=https://linux-2080ti.local

# Agent machines only.
# Set the outbound registration key to the controller's
# NEURAXIS_CONTROLLER_REGISTRATION_KEY before running scripts/onboard_agent.sh.
export NEURAXIS_CONTROLLER_REGISTRATION_KEY_OUTBOUND=replace-with-controller-registration-key
export NEURAXIS_CONTROLLER_URL=https://pi-controller.local
export NEURAXIS_AGENT_URL=https://this-agent.local
# scripts/onboard_agent.sh generates this if it is absent. Leave commented
# unless you are intentionally reusing a real agent API key.
# export NEURAXIS_AGENT_API_KEY=replace-with-agent-api-key

# Private-CA TLS only. Use local paths for the account running Neuraxis.
# export SSL_CERT_FILE=/home/USER/neuraxis-certs/neuraxis-ca-chain.crt
# export REQUESTS_CA_BUNDLE=/home/USER/neuraxis-certs/neuraxis-ca-chain.crt
