# Copy this file to .llama_pack.env on each machine and replace placeholders.
# .llama_pack.env is ignored by git and may contain local secrets.

# Common runtime bind. Use 127.0.0.1 when Caddy/TLS fronts the app.
# Use 0.0.0.0 only for direct LAN HTTP without Caddy.
export LLAMA_PACK_HOST=127.0.0.1
export LLAMA_PACK_PORT=9137

# Controller machine only.
# scripts/onboard_controller.sh writes generated values for fresh controller
# setup. Leave these commented unless you are intentionally reusing real values.
export LLAMA_PACK_CONFIG=./config.yaml
# export LLAMA_PACK_CONTROLLER_REGISTRATION_KEY=replace-with-controller-registration-key
# export LLAMA_PACK_CONTROLLER_ADMIN_API_KEY=replace-with-admin-api-key
export LLAMA_PACK_MAC_MINI_AGENT_URL=https://mac-mini.local
export LLAMA_PACK_LINUX_2080TI_AGENT_URL=https://linux-2080ti.local

# Agent machines only.
# Set the outbound registration key to the controller's
# LLAMA_PACK_CONTROLLER_REGISTRATION_KEY before running scripts/onboard_agent.sh.
export LLAMA_PACK_CONTROLLER_REGISTRATION_KEY_OUTBOUND=replace-with-controller-registration-key
export LLAMA_PACK_CONTROLLER_URL=https://pi-controller.local
export LLAMA_PACK_AGENT_URL=https://this-agent.local
# scripts/onboard_agent.sh generates this if it is absent. Leave commented
# unless you are intentionally reusing a real agent API key.
# export LLAMA_PACK_AGENT_API_KEY=replace-with-agent-api-key

# Private-CA TLS only. Use local paths for the account running Llama Pack.
# export SSL_CERT_FILE=/home/USER/llama-pack-certs/llama-pack-ca-chain.crt
# export REQUESTS_CA_BUNDLE=/home/USER/llama-pack-certs/llama-pack-ca-chain.crt
